  "description": "Bot telegram untuk order nomor virtual",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon src/app.ts",
    "build": "tsup src/app.ts --format cjs --target node20 --minify --sourcemap --clean --out-dir dist",
    "build:prod": "tsup src/app.ts --format cjs --target node20 --minify --clean --out-dir dist",
    "typecheck": "tsc --noEmit",
    "start": "node dist/app.js"
  },
  "keywords": [],
  "author": "Oxyda ID",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.15.0",
    "body-parser": "^2.2.2",
    "consola": "^3.4.2",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "moment-timezone": "^0.6.1",
    "mongoose": "^9.4.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
